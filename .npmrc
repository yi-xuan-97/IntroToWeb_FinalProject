# npm v7+ enforces peer dependency matches strictly. This project still has
# Material UI v4 (declares peer react ^16.8.0 || ^17.0.0) running alongside
# React 18 — works fine in practice, but npm 7+ refuses to install it.
#
# Setting legacy-peer-deps=true makes npm fall back to the npm v6 behavior:
# warn on peer mismatches instead of erroring out. Keeps local + Vercel in
# sync, no other side effects on the build.
#
# Long-term fix: finish migrating off Material UI entirely, then delete this
# file. See tailwind_preflight_trap memory for related cleanup.
legacy-peer-deps=true
