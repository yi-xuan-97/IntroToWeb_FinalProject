# Copy this file to `.env` and fill in your real EmailJS credentials.
# Get them from https://dashboard.emailjs.com/
#
# Note: CRA exposes any env var prefixed with REACT_APP_ to the browser bundle.
# These values will be visible in the deployed JS, so don't put real secrets here.
# (EmailJS public keys are designed for client-side use; your account still
# enforces rate limits and allowed-origin restrictions.)

REACT_APP_EMAILJS_SERVICE_ID=service_xxxxxxx
REACT_APP_EMAILJS_TEMPLATE_ID=template_xxxxxxx
REACT_APP_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx
